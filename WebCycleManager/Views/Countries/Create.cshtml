@model Domain.Models.Country

<h3>Maak nieuw land</h3>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="CountryNameLong" class="control-label"></label>
                <input asp-for="CountryNameLong" class="form-control" />
                <span asp-validation-for="CountryNameLong" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="CountryNameShort" class="control-label"></label>
                <input asp-for="CountryNameShort" class="form-control" />
                <span asp-validation-for="CountryNameShort" class="text-danger"></span>
            </div>
            <div class="mt-3 d-flex justify-content-between gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary">Terug naar de lijst</a>
                <button type="submit" class="btn btn-primary">Maak</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
