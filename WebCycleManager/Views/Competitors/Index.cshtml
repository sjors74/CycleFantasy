@model PaginatedList<Domain.Dto.CompetitorDto>

@{
    var availableYears = (List<int>)ViewData["AvailableYears"];
    var selectedYear = (int)ViewData["SelectedYear"];
    var half = (int)Math.Ceiling(Model.Count / 2.0);
    var leftItems = Model.Take(half).ToList();
    var rightItems = Model.Skip(half).ToList();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Renners</h1>

    <!-- Jaar Tabs rechts van de titel -->
    <ul class="nav nav-tabs">
        @foreach (var year in availableYears)
        {
            <li class="nav-item">
                <a class="nav-link @(year == selectedYear ? "active" : "")"
                   asp-action="Index"
                   asp-route-year="@year"
                   asp-route-SearchString="@ViewData["CurrentFilter"]">
                    @year
                </a>
            </li>
        }
    </ul>
</div>

<!-- Compact zoekformulier -->
<form asp-action="Index" method="get" class="d-flex align-items-center mb-3">
    <label class="me-2 mb-0">Zoek op naam:</label>
    <input type="hidden" name="year" value="@(selectedYear)" />
    <input type="text" name="SearchString" value="@ViewData["CurrentFilter"]"
           class="form-control form-control-sm me-2" style="width:150px;" />
    <input type="submit" value="Zoek" class="btn btn-secondary btn-sm me-2" />
    <a asp-action="Index" class="btn btn-link btn-sm mb-0">Terug naar volledige lijst</a>
</form>

<div class="row" style="max-height: calc(100vh - 200px); overflow-y:auto;">
   @foreach (var column in new[] { leftItems, rightItems })
   {
        <div class="col-md-6 mb-3">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Voornaam</th>
                        <th>Achternaam</th>
                        <th>Land</th>
                        <th class="text-end">Acties</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in column)
                    {
                        <tr>
                            <td>@item.FirstName</td>
                            <td>@item.LastName</td>
                            <td style="width:80px;">@(item.CountryShort ?? "onbekend")</td>
                            <td class="text-end">
                               <div class="btn-group" role="group">
                                    <a asp-action="Edit" asp-route-id="@item.CompetitorId"
                                       class="btn btn-sm btn-outline-primary" title="Bewerken">
                                           <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.CompetitorId"
                                        class="btn btn-sm btn-outline-secondary" title="Details">
                                            <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.CompetitorId"
                                        class="btn btn-sm btn-outline-danger" title="Verwijderen">
                                            <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                     }
                </tbody>
            </table>
        </div>
     }
</div>

<!-- Paginate -->

<div class="d-flex justify-content-between mt-3">
    @if (Model.HasPreviousPage)
    {
        <a asp-action="Index"
        asp-route-pageNumber="@(Model.PageIndex - 1)"
        asp-route-year="@(selectedYear)"
        asp-route-currentFilter="@ViewData["CurrentFilter"]"
        class="btn btn-outline-secondary btn-sm">
            Vorige
        </a>
    }
    else
    {
        <button class="btn btn-outline-secondary btn-sm" disabled>Vorige</button>
    }

    @if (Model.HasNextPage)
    {
        <a asp-action="Index"
        asp-route-pageNumber="@(Model.PageIndex + 1)"
        asp-route-year="@(selectedYear)"
        asp-route-currentFilter="@ViewData["CurrentFilter"]"
        class="btn btn-outline-secondary btn-sm">
            Volgende
        </a>
    }
    else
    {
        <button class="btn btn-outline-secondary btn-sm" disabled>Volgende</button>
    }

</div>
