@model PaginatedList<Domain.Dto.CompetitorDto>

@{
    ViewData["Title"] = "Index";
}

<h1>Renners</h1>

<p>
    <a asp-action="Create">Maak nieuw</a>
</p>

<form asp-action="Index" method="get">
    <div class="form-actions no-color">
        <p>
            Zoek op naam: <input type="text" name="SearchString" value="@ViewData["CurrentFilter"]" />
            <select name="year" onchange="this.form.submit()">
                @foreach (var year in (List<int>)ViewData["AvailableYears"])
                {
                    <option value="@year" selected="@(year == (int)ViewData["SelectedYear"])">
                        @year
                    </option>
                }
            </select>
            <input type="submit" value="Zoek" class="btn btn-default" /> |
            <a asp-action="Index">Terug naar de volledige lijst</a>
        </p>
    </div>
</form>
<table class="table">
    <thead>
        <tr>
             <th>
                @Html.DisplayName("Voornaam")
            </th>
             <th>
                @Html.DisplayName("Achternaam")
            </th>
            <th>
                @Html.DisplayName("Pcs-naam")
            </th>
            <th>
                @Html.DisplayName("Land")
            </th>
            <th></th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.FirstName)
            </td>
             <td>
                @Html.DisplayFor(modelItem => item.LastName)
            </td>
             <td>
                @Html.DisplayFor(modelItem => item.PcsName)
            </td>
            <td>
                    @(item.CountryShort ?? "onbekend")
            </td>
            <td>
                @item.Teams.FirstOrDefault().TeamName
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.CompetitorId">Wijzig</a> |
                <a asp-action="Details" asp-route-id="@item.CompetitorId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.CompetitorId">Verwijder</a>
            </td>
        </tr>
}
    </tbody>
</table>
@{
    var prevDisabled = !Model.HasPreviousPage ? "disabled" : "";
    var nextDisabled = !Model.HasNextPage ? "disabled" : "";
}

<a asp-action="Index"
   asp-route-pageNumber="@(Model.PageIndex - 1)"
   class="btn btn-default @prevDisabled">
    Vorige
</a>
<a asp-action="Index"
   asp-route-pageNumber="@(Model.PageIndex + 1)"
   class="btn btn-default @nextDisabled">
    Volgende
</a>
