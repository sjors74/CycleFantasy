@model CycleManager.Domain.Dto.DeelnemerDeleteDto

<h1>Verwijder</h1>
<h3>Weet je zeker dat je deze deelnemer wilt verwijderen?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">Team</dt>
        <dd class = "col-sm-10">@Model.TeamName</dd>

        <dt class = "col-sm-2">Gebruiker</dt>
        <dd class = "col-sm-10">@Model.UserName</dd>

        <dt class = "col-sm-2">Evenement</dt>
        <dd class = "col-sm-10">@Model.EventName</dd>
    </dl>
    
    <form asp-action="DeleteConfirmed" method="post">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="EventId" />
        <input type="submit" value="Verwijder" class="btn btn-danger" /> |
        <a asp-action="Index" asp-route-eventId="@Model.EventId">Terug naar de lijst</a>
    </form>
</div>
