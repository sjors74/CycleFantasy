@using CycleManager.Domain.Dto
@model DeelnemerCreateDto

<h3>Nieuwe deelnemer</h3>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="EventId" />

            <div class="form-group">
                <label asp-for="TeamName" class="control-label"></label>
                <input asp-for="TeamName" class="form-control" />
                <span asp-validation-for="TeamName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="UserId" class="control-label">Gebruiker</label>
                <select asp-for="UserId" class ="form-control" asp-items="@(ViewData["Users"] as List<SelectListItem>)"></select>
                <span asp-validation-for="UserId" class="text-danger"></span>
            </div>
            <div class="mt-3 d-flex justify-content-between gap-2">
                <a asp-action="Index" asp-route-eventId="@Model.EventId" class="btn btn-outline-secondary">Terug naar de lijst</a>
                <button type="submit" class="btn btn-primary">Maak</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
