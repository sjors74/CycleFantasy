@model IEnumerable<PointsCompetitorInEventViewModel>

    <h3>Ranglijst renners</h3>
    @if (Model.Any())
    {

        <div style="max-height: calc(100vh - 250px); overflow-y:auto;">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>
                            @Html.DisplayName("Nr")
                        </th>
                        <th>
                            @Html.DisplayName("Naam")
                        </th>
                        <th>
                            @Html.DisplayName("Punten")
                        </th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @Html.DisplayFor(modelItem => item.Ranking)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.CompetitorName)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Points)
                            </td>
                            <td>

                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
}
else
{
    <p>Geen resultaten om weer te geven.</p>
}
<div class="mt-3 d-flex gap-2">
    <a asp-controller="Events" asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Terug naar de lijst
    </a>
</div>