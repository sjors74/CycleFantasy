@model WebCycleManager.Models.EventItemViewModel
<div class="modal fade" id="manageTeamsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header d-flex justify-content-between align-items-center">
                <h5 class="modal-title">Teams beheren</h5>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Annuleren</button>
                    <button type="submit" class="btn btn-primary btn-sm" form="manageTeamsForm">Opslaan</button>
                </div>
            </div>
            <div class="modal-body" id="manageTeamsContent">
                <div id="teamsLoader" class="d-flex justify-content-center align-items-center" style="min-height:150px;">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Laden...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>