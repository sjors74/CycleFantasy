@using System.Text.Json
@using System.Text.Json.Serialization
@model ResultViewModel
<h1>@Model.StageName</h1>
<div id="autocomplete-root" data-count="@Model.ConfigurationItems"></div>

@if(Model.NoScore)
{
    <div class="alert alert-info" role="alert">
        <h5 class="alert-heading">Geen scores voor deze etappe</h5>
        <p>@Model.NoScoreDescription</p>
    </div>
}
else
{
    <form method="post" asp-controller="Results" asp-action="Index">
        <table class="table table-striped table-hover">
            <thead class="table-light">
                <tr>
                    <th>
                        @Html.DisplayNameFor(model => model.Results.First().Position)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Results.First().CompetitorName)
                    </th>
                    <th></th>
                </tr>
            </thead>
            <tbody>

                @for(var i = 0; i < Model.ConfigurationItems; i++) {
                    <tr>
                        <td>
                            @Html.HiddenFor(model => model.EventId)
                            @Html.HiddenFor(model => model.Results[i].Position)
                            <label>@Model.Results[i].Position</label>
                        </td>
                        <td>
                            @if (Model.Results[i].SelectedCompetitorId > 0)
                            {
                                <label>@Model.Results[i].CompetitorName</label>
                                @Html.HiddenFor(m => m.Results[i].SelectedCompetitorId)
                            }
                            else
                            {
                                <input 
                                    type="text"
                                    id="competitor-autocomplete-@i"
                                    name="Results[@i].CompetitorName"
                                    value="@Model.Results[i].CompetitorName" 
                                    placeholder="Typ hier naam..."
                                    autocomplete="on"
                                    />
                                 <input type="hidden" name="Results[@i].SelectedCompetitorId" id="selectedCompetitorId-@i" value="@Model.Results[i].SelectedCompetitorId" />
                            }
                        </td>
                        <td>
                            @if (Model.Results[i].Id > 0)
                            {
                                <a asp-action="Delete" asp-route-id="@Model.Results[i].Id"
                                   class="btn btn-sm btn-outline-danger"
                                   title="Verwijderen">
                                    <i class="bi bi-trash"></i>
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <h3>Specials</h3>

        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Special</th>
                    <th>Deelnemer</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @for (var i = 0; i < Model.SpecialResults.Count; i++)
                {
                    <tr>
                        <td>@Model.SpecialResults[i].SpecialName</td>
                        <td>
                            <input type="text"
                                   id="competitor-autocomplete-@i"
                                   name="SpecialResults[@i].CompetitorName"
                                   value="@Model.SpecialResults[i].CompetitorName"
                                   placeholder="Typ hier naam..."
                                   autocomplete="on" />
                            <input type="hidden" name="SpecialResults[@i].SelectedCompetitorId" id="selectedCompetitorId-@i" value="@Model.SpecialResults[i].SelectedCompetitorId" />
                        </td>
                        <td>
                            @if (Model.SpecialResults[i].SpecialId > 0)
                            {
                                <a asp-action="Delete" asp-route-id="@Model.SpecialResults[i].SpecialId"
                                   class="btn btn-sm btn-outline-danger"
                                   title="Verwijderen">
                                    <i class="bi bi-trash"></i>
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <input type="hidden" id="configurationId" name="configurationId" value="@Model.ConfigurationId" />
        <input type="hidden" id="stageId" name="stageId" value="@Model.StageId" />
        <div class="mt-3 d-flex justify-content-between gap-2">
            <a asp-controller="Events" asp-action="Details" asp-route-id="@Model.EventId" class="btn btn-outline-secondary">Terug naar evenement</a>
            <button type="submit" class="btn btn-primary">Opslaan</button>
        </div>
    </form>
}

@{
    var options = new JsonSerializerOptions
    {
        ReferenceHandler = ReferenceHandler.IgnoreCycles,
        MaxDepth = 128,
        WriteIndented = false
    };

    var competitorsJson = JsonSerializer.Serialize(
        Model.Competitors
             .Select(c => c.CompetitorInTeam)
             .Select(cit => cit.Competitor)
             .ToList(),
        options
    );
}
<script>
    const competitors = @Html.Raw(competitorsJson);
    const configurationItemCount = @Model.ConfigurationItems;
</script>