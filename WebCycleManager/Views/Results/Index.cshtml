@using System.Text.Json
@using System.Text.Json.Serialization
@model ResultViewModel
<h1>@Model.StageName</h1>
<div id="autocomplete-root" data-count="@Model.ConfigurationItems"></div>

@if(Model.NoScore)
{
    <div class="alert alert-info" role="alert">
        <h5 class="alert-heading">Geen scores voor deze etappe</h5>
        <p>@Model.NoScoreDescription</p>
    </div>
}
else
{
    <form method="post" asp-controller="Results" asp-action="Index">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th style="width:180px;">Positie / Special</th>
                    <th>Renner</th>
                    <th style="width:60px"></th>
                </tr>
            </thead>

            <tbody>

                @for (var i = 0; i < Model.Rows.Count; i++)
                {
                    <tr>

                        <td>
                            @Model.Rows[i].Label
                        </td>

                        <td>

                            @if (Model.Rows[i].SelectedCompetitorId > 0)
                            {
                                <label>@Model.Rows[i].CompetitorName</label>
                                @Html.HiddenFor(m => m.Rows[i].SelectedCompetitorId)
                            }
                            else
                            {
                                <div class="autocomplete-wrapper">
                                    <input type="text"
                                       class="competitor-autocomplete"
                                       id="competitor-autocomplete-row-@i"
                                       data-id-input="SelectedCompetitorId"
                                       name="Rows[@i].CompetitorName" />

                                <input type="hidden"
                                       class="competitor-id"
                                       name="Rows[@i].SelectedCompetitorId"
                                       value="@Model.Rows[i].SelectedCompetitorId" />
                                </div>
                            }

                        </td>

                        <td>

                            @if (Model.Rows[i].Id > 0)
                            {
                                <a asp-action="@Model.Rows[i].DeleteAction"
                                   asp-route-id="@Model.Rows[i].Id"
                                   class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </a>
                            }

                        </td>

                    </tr>
                    @Html.HiddenFor(m => m.Rows[i].Id)
                    @Html.HiddenFor(m => m.Rows[i].IsSpecial)
                    @Html.HiddenFor(m => m.Rows[i].Position)
                    @Html.HiddenFor(m => m.Rows[i].SpecialId)
                    
                    
                }

            </tbody>
        </table>

        <input type="hidden" id="configurationId" name="configurationId" value="@Model.ConfigurationId" />
        <input type="hidden" id="stageId" name="stageId" value="@Model.StageId" />
        <input type="hidden" id="eventId" name="eventId" value="@Model.EventId" />

        
        <div class="mt-3 d-flex justify-content-between gap-2">
            <a asp-controller="Events" asp-action="Details" asp-route-id="@Model.EventId" class="btn btn-outline-secondary">Terug naar evenement</a>
            <button type="submit" class="btn btn-primary">Opslaan</button>
        </div>
    </form>
}

@{
    var options = new JsonSerializerOptions
    {
        ReferenceHandler = ReferenceHandler.IgnoreCycles,
        MaxDepth = 128,
        WriteIndented = false
    };

    var competitorsJson = JsonSerializer.Serialize(
        Model.Competitors
             .Select(c => c.CompetitorInTeam)
             .Select(cit => cit.Competitor)
             .ToList(),
        options
    );
}
<script>
    window.competitors = @Html.Raw(competitorsJson);
    window.configurationItemCount = @Model.ConfigurationItems;
</script>