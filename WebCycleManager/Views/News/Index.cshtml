@model IEnumerable<Domain.Models.NewsItem>

<h2>Nieuwsitems</h2>
<p><a asp-action="Create" class="btn btn-primary">Nieuw nieuwsitem toevoegen</a></p>

<table class="table">
    <thead>
        <tr>
            <th>Titel</th>
            <th>Datum</th>
            <th>Actief</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.DatePosted.ToString("dd-MM-yyyy HH:mm")</td>
                <td>@(item.IsActive ? "Ja" : "Nee")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Bewerk</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Verwijder</a>
                </td>
            </tr>
        }
    </tbody>
</table>
