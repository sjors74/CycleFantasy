@model IEnumerable<Domain.Models.NewsItem>
<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Nieuwsitems</h3>
    <div class="d-flex gap-2">
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Nieuw item toevoegen
        </a>
    </div>
</div>
<table class="table">
    <thead>
        <tr>
            <th>Titel</th>
            <th>Datum</th>
            <th>Actief</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.DatePosted.ToString("dd-MM-yyyy HH:mm")</td>
                <td>@(item.IsActive ? "Ja" : "Nee")</td>
                <td>
                    <div class="d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@item.Id" title="Bewerken" aria-label="Bewerken">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.Id" title="Verwijderen" aria-label="Verwijderen">
                            <i class="bi bi-trash"></i>
                        </a>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>
