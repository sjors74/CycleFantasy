@model CompetitorsInEventViewModel

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Renners @Model.EventNameLong</h3>
    <div class="d-flex gap-2">
        <a asp-action="Create" asp-route-eventId="@Model.EventId" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Voeg renner(s) toe
        </a>
    </div>
</div>

<form asp-action="Index" method="get" name="CompetitorsInEvents">
    <select asp-for="FilterTeam"
        asp-items="Model.Teams" onchange="SelectedIndexChanged(this.value)">
        <option>Selecteer team</option>
    </select>
</form>
<div style="max-height: calc(100vh - 250px); overflow-y:auto;">
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>
                    @Html.DisplayName("Nummer")
                </th>
                <th>
                    Renner
                </th>
                <th>
                    @Html.DisplayName("Team")
                </th>
                <th>
                    @Html.DisplayName("Uitgevallen")
                </th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model.Competitors) {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.EventNumber)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.CompetitorName)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.TeamName)
                </td>
                <td>
                    @(item.OutOfCompetition ? "ja" : "")
                </td>
                <td>
                    <div class="d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@item.CompetitorInEventId" title="Bewerken" aria-label="Bewerken">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.CompetitorInEventId" title="Verwijderen" aria-label="Verwijderen">
                            <i class="bi bi-trash"></i>
                        </a>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
<script type="text/javascript">
    function SelectedIndexChanged(searchTeam) {
        var eventId = @Model.EventId;
        window.location.href = "/CompetitorsInEvents/Index?eventId=" + eventId + "&FilterTeam=" + searchTeam;
    }
</script> 