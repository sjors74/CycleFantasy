@model CompetitorsInEventViewModel

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Renners @Model.EventNameLong</h3>
    <div class="d-flex gap-2">
        <a asp-action="Index" asp-controller="Events" class="btn btn-outline-secondary">Terug naar evenement</a>
        <form id="syncRennersForm" asp-action="ManageRenners"
              asp-controller="Events"
              method="post">

            <input type="hidden"
                   name="eventId"
                   value="@Model.EventId" />

            <button type="submit"
                    class="btn btn-outine-primary">
                Renners synchroniseren
            </button>
        </form>
        <a asp-action="Create" asp-route-eventId="@Model.EventId" asp-route-FilterTeam="@Model.FilterTeam" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Voeg renner(s) toe
        </a>
    </div>
</div>

<div class="d-flex align-items-center gap-3 mb-3">
    <form asp-action="Index" method="get" name="CompetitorsInEvents">
        <select asp-for="FilterTeam"
            asp-items="Model.Teams" 
             class="form-select form-select-sm"
             onchange="SelectedIndexChanged(this.value)">
            <option>Selecteer team</option>
        </select>
    </form>
    <h4 class="mb-0 d-flex gap-2">
        <span class="badge bg-primary">
            @Model.ActiveCompetitors
        </span>

        @if (Model.RemovedCompetitors > 0)
        {
            <span class="badge bg-danger">
                @Model.RemovedCompetitors
            </span>
        }
    </h4>
</div>

<div style="max-height: calc(100vh - 250px); overflow-y:auto;">
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>@Html.DisplayName("Nummer")</th>
                <th>Renner</th>
                <th>@Html.DisplayName("Team")</th>
                <th>In selectie</th>
                <th>@Html.DisplayName("Uitgevallen")</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model.Competitors) {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.EventNumber)</td>
                <td>@Html.DisplayFor(modelItem => item.CompetitorName)</td>
                <td>@Html.DisplayFor(modelItem => item.TeamName)</td>
                    <td>
                        @if (item.InSelection)
                        {
                            <i class="bi bi-check-circle text-success" title="in selectie"></i>
                        }
                    </td>
                    <td>
                        @if (item.OutOfCompetition)
                        {
                            <i class="bi bi-check-circle text-success" title="uitgevallen"></i>
                        }

                    </td>
                <td>
                    <div class="d-flex gap-2">
                            <a asp-action="Edit" asp-route-id="@item.CompetitorInEventId" asp-route-eventId="@item.EventId" asp-route-FilterTeam="@Model.FilterTeam" title="Bewerken" aria-label="Bewerken">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.CompetitorInEventId" asp-route-eventId="@item.EventId" asp-route-FilterTeam="@Model.FilterTeam" title="Verwijderen" aria-label="Verwijderen">
                            <i class="bi bi-trash"></i>
                        </a>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger" role="alert">
        @TempData["ErrorMessage"]
    </div>
}
<script type="text/javascript">
    function SelectedIndexChanged(searchTeam) {
        var eventId = @Model.EventId;
        window.location.href = "/CompetitorsInEvents/Index?eventId=" + eventId + "&FilterTeam=" + searchTeam;
    }
</script> 
<script>
   (function () {
    // =========================
    // RENNERS SYNCHRONISEREN
    // =========================
    var syncForm = document.getElementById('syncRennersForm');
    if (syncForm) {

        syncForm.addEventListener('submit', function (e) {
            e.preventDefault();

            if (typeof Swal === 'undefined') {
                if (!confirm('Startlist synchroniseren vanaf PCS? Bestaande deelnemers worden bijgewerkt.')) return;
                syncForm.submit();
                return;
            }

            Swal.fire({
                title: 'Renners synchroniseren?',
                text: 'De actuele startlijst wordt opgehaald vanaf PCS. Deelnemers en rugnummers worden bijgewerkt.',
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Ja, synchroniseren',
                cancelButtonText: 'Annuleren'
            }).then(function (result) {

                if (result.isConfirmed) {

                    var btn = syncForm.querySelector('button[type="submit"]');
                    if (btn) {
                        btn.disabled = true;
                        btn.classList.add('disabled');
                    }

                    syncForm.submit();
                }
            });
        });
    }
  })();
</script>