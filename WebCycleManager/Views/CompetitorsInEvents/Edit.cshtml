@model CompetitorInEventViewModel

<h3>@Model.CompetitorName</h3>

<h4>@Model.EventName</h4>

<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="CompetitorInEventId" />
            <input type="hidden" asp-for="EventId" />
            <input type="hidden" asp-for="TeamId" />
            <div class="form-group">
                <label asp-for="EventNumber" class="control-label"></label>
                <input asp-for="EventNumber" class="form-control" />
                <span asp-validation-for="EventNumber" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="InSelection" class="control-label"></label>
                <input type="checkbox" asp-for="InSelection" />
                <span asp-validation-for="InSelection" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="OutOfCompetition" class="control-label"></label>
                <input type="checkbox" asp-for="OutOfCompetition"  />
                <span asp-validation-for="OutOfCompetition" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Opslaan" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>
    
<div class="mt-3 d-flex gap-2">
    <a asp-action="Index" asp-route-eventId="@Model.EventId" asp-route-FilterTeam="@Model.TeamId.ToString()" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Terug naar de lijst
    </a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
