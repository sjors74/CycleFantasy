@model Domain.Models.CompetitorsInEvent


<h3>Voeg renners toe aan evenement</h3>
<div class="row">
    <div class="col-md-12">
        <form asp-action="Create" asp-controller="CompetitorsInEvents" method="post" class="form-control" role="form">
            <input type="hidden" id="year" name="year" value="@(DateTime.Now.Year)" />
            <input type="hidden" name="FilterTeam" value="@Context.Request.Query["FilterTeam"]" />
            <div class="form-group">
                <div class="row">
                    <div class="col-xs-12 col-sm-6 col-md-10 col-lg-14">
                        <label class="control-label">Filter op team</label>
                         <select id="SelectTeamId" name="SelectTeamId"
                            class ="form-control"
                                asp-items="@(new SelectList(@ViewBag.ListOfTeams, "TeamId", "CurrentTeamName", @Context.Request.Query["FilterTeam"]))">
                            <option value="0">Selecteer...</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="form-group">
                <div class="row">
                    <div class="row-cols-md-auto">
                        <label class="control-label">Renners</label>
                        <select multiple="multiple" class="form-control" id="SelectCompetitorId" name="SelectCompetitorId" asp-for="CompetitorInTeamId" size="20"
                        asp-items="ViewBag.ListOfCompetitors"></select>
                    </div>
                </div>
            </div>
            <div class="mt-3 d-flex justify-content-between gap-2">
                <a asp-controller="CompetitorsInEvents" asp-action="Index" asp-route-eventId="@ViewBag.EventId" asp-route-FilterTeam="@Context.Request.Query["FilterTeam"]" class="btn btn-outline-secondary">Terug naar de lijst</a>
                <button type="submit" class="btn btn-primary" asp-route-eventId="@ViewBag.EventId" asp-route-FilterTeam="@Context.Request.Query["FilterTeam"]">Voeg toe</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script type="text/javascript">
        $(document).ready(function () {
            $('#SelectTeamId').change(function() {
                var url = '@Url.Content("~/")' + "CompetitorsInEvents/GetCompetitorForEvent";
                var ddlsource = "#SelectTeamId";
                $.getJSON(url, { TeamId: $(ddlsource).val(), year: $('#year').val() }, function(data) {
                    var items = '';
                    $("#SelectCompetitorId").empty();
                    $.each(data, function(i, competitor) {
                        items += "<option value='" + competitor.value + "'>" +  competitor.text + "</option>";
                    });
                    $('#SelectCompetitorId').html(items);
                });
            });
        });
    </script>
}
