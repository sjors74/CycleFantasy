@model EventViewModel

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Evenementen</h3>
    <div class="d-flex gap-2">
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Maak evenement aan
        </a>
    </div>
</div>

<table class="table table-hover align-middle">
    <thead class="table-light">
        <tr>
            <th>@Html.DisplayName("Naam")</th>
            <th>@Html.DisplayName("Jaar")</th>
            <th>@Html.DisplayName("Startdatum")</th>
            <th>@Html.DisplayName("Einddatum")</th>
            <th>@Html.DisplayName("Actief")</th>
            <th>@Html.DisplayName("Show podium")</th>
            <th colspan="2" class="text-center">Acties</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Events)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Year</td>
                <td>@item.StartDate.ToString("dd-MM-yyyy")</td>
                <td>@item.EndDate.ToString("dd-MM-yyyy")</td>
                <td>
                    @if (item.IsActive)
                    {
                        <i class="bi bi-check-circle text-success" title="Actief"></i>
                    }
                    else
                    {
                        <i class="bi bi-x-circle text-danger" title="Niet actief"></i>
                    }
                </td>
                <td>
                    @if (item.ShowPodium)
                    {
                        <i class="bi bi-check-circle text-success" title="Podium wordt getoond"></i>
                    }
                    else
                    {
                        <i class="bi bi-x-circle text-danger" title="Podium wordt niet getoond"></i>
                    }
                </td>
                <td>
                    <div class="d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@item.Id" title="Bewerken" aria-label="Bewerken">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <a asp-action="Details" asp-route-id="@item.Id" title="Details" aria-label="Details">
                            <i class="bi bi-eye"></i>
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.Id" title="Verwijderen" aria-label="Verwijderen">
                            <i class="bi bi-trash"></i>
                        </a>
                    </div>
                </td>
                <td>
                    <div class="d-flex gap-2">
                        <a asp-controller="CompetitorsInEvents" asp-route-eventId="@item.Id" asp-action="Index" title="Renners" aria-label="Renners">
                            <i class="bi bi-bicycle"></i>
                        </a>
                        <a asp-controller="Points" asp-route-eventId="@item.Id" asp-action="Index" title="Punten" aria-label="Punten">
                            <i class="bi bi-123"></i>
                        </a>
                        @if (item.IsActive)
                        {
                            <a asp-controller="GameCompetitorEvents" asp-route-eventId="@item.Id" asp-action="Index" title="Deelnemers" aria-label="Deelnemers">
                                <i class="bi bi-people"></i>
                            </a>
                        }
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>