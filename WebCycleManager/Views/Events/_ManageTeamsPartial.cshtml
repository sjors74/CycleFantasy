@using WebCycleManager.Models
@model EventTeamsViewModel

<form asp-action="ManageTeams" method="post" id="manageTeamsForm">
    <input type="hidden" asp-for="EventId" />

    <div class="row">
        @for (int i = 0; i < Model.Teams.Count; i++)
        {
            var cssClass = Model.Teams[i].IsSelected ? "bg-success bg-opacity-10 border rounded p-2" : "bg-light border rounded p-2";
            <div class="col-md-6 mb-2">
                <div class="form-check @cssClass">
                    <label class="d-flex justify-content-between align-items-center @cssClass" for="team-@i">
                        <span>@Model.Teams[i].TeamName</span>
                        <input type="checkbox" asp-for="Teams[i].IsSelected" id="team-@i" />
                    </label>
                    <input type="hidden" asp-for="Teams[i].TeamId" />
                    <input type="hidden" asp-for="Teams[i].TeamName" />
                </div>
            </div>
        }
    </div>
    <div class="modal-footer">
        <button type="submit" class="btn btn-primary">Opslaan</button>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuleren</button>
    </div>
</form>
