@model EventItemViewModel

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0">@Model.EventNameDescription</h3>
    <div class="d-flex gap-2">
        <a href="#"
           class="btn btn-secondary position-relative"
           data-bs-toggle="modal"
           data-bs-target="#manageTeamsModal"
           data-url="@Url.Action("ManageTeams", "Events", new { id = Model.Id })">
            Teams beheren
            <span class="badge bg-light text-dark ms-2">@Model.SelectedTeamsCount</span>
        </a>
        <a href="#"
           class="btn btn-secondary position-relative"
           data-bs-toggle="modal"
           data-bs-target="#manageStagesModal"
           data-url="@Url.Action("ManageStages", "Events", new { eventId = Model.Id })">
            Stages
            <span class="badge bg-light text-dark ms-2">@Model.StagesInEvent</span>
        </a>
    </div>
</div>
<form asp-action="Edit">
    <input type="hidden" asp-for="Id" />
    <div class="card mb-3 shadow-sm">
        <div class="card-header fw-bold">Algemene gegevens</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Year" class="form-label"></label>
                    <input asp-for="Year" class="form-control" />
                    <span asp-validation-for="Year" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Code" class="form-label"></label>
                    <input asp-for="Code" class="form-control" />
                    <span asp-validation-for="Code" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="StartDate" class="form-label"></label>
                    <input asp-for="StartDate" class="form-control" />
                    <span asp-validation-for="StartDate" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="EndDate" class="form-label"></label>
                    <input asp-for="EndDate" class="form-control" />
                    <span asp-validation-for="EndDate" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="ConfigurationId" class="form-label"></label>
                    <select asp-for="ConfigurationId" class="form-select" asp-items="ViewBag.ConfigurationId"></select>
                </div>
            </div>
        </div>
    </div>
    <div class="card mb-3 shadow-sm">
        <div class="card-header fw-bold">Visuele instellingen</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Slogan" class="form-label"></label>
                    <input asp-for="Slogan" class="form-control" />
                    <span asp-validation-for="Slogan" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="CountryCode" class="form-label"></label>
                    <input asp-for="CountryCode" class="form-control" />
                    <span asp-validation-for="CountryCode" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="ColorName" class="form-label"></label>
                    <input type="color" asp-for="ColorName" class="form-control" />
                    <span asp-validation-for="ColorName" class="text-danger"></span>
                </div>
                <div class="col-md-6 form-check mt-3">
                    <input type="checkbox" asp-for="IsActive" class="form-check-input" id="isActive" />
                    <label for="isActive" class="form-check-label">@Html.DisplayNameFor(m => m.IsActive)</label>
                </div>
                <div class="col-md-6 form-check mt-3">
                    <input type="checkbox" asp-for="ShowPodium" class="form-check-input" id="showPodium" />
                    <label for="showPodium" class="form-check-label">@Html.DisplayNameFor(m => m.ShowPodium)</label>
                </div>
            </div>
        </div>
    </div>
    <div class="d-flex justify-content-between align-items-center mt-4">
            <a asp-action="Index" class="btn btn-outline-secondary">Terug naar de lijst</a>
            <button type="submit" class="btn btn-primary me-2">Opslaan</button>
    </div>
</form>
@await Html.PartialAsync("_ManageTeamsModal", Model)
@await Html.PartialAsync("_ManageStagesModal", Model)
@await Html.PartialAsync("_EditStageModal")

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            /*** Generieke functie: modal content via AJAX laden ***/
            function setupModal(modalId, contentId) {
                const modalEl = document.getElementById(modalId);
                if (!modalEl) return;

                modalEl.addEventListener('show.bs.modal', function(event) {
                    const button = event.relatedTarget;
                    const url = button?.dataset.url;
                    if (!url) return;

                    const contentEl = document.getElementById(contentId);
                    if (!contentEl) return;

                    // Loader tonen
                    contentEl.innerHTML = `
                        <div class="d-flex justify-content-center align-items-center" style="min-height:150px;">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Laden...</span>
                            </div>
                        </div>
                    `;

                    fetch(url)
                        .then(res => res.text())
                        .then(html => {
                            contentEl.innerHTML = html;
                            initStageModalControls(contentId);
                        })
                    });
            }

            /*** AJAX formulier submit in modal ***/
            function setupAjaxForm(modalContentId) {
                document.getElementById(modalContentId)?.addEventListener('submit', function(e) {
                    const form = e.target.closest('form');
                    if (!form) return;

                    e.preventDefault();
                    const formData = new FormData(form);

                    fetch(form.action, { method: 'POST', body: formData })
                        .then(res => res.json())
                        .then(data => {
                            const modalContent = document.getElementById(modalContentId);
                            const modalEl = modalContent.closest('.modal');
                            const modal = bootstrap.Modal.getOrCreateInstance(modalEl);

                            if (data.success) {
                                // Bijwerken van tabelrij als 'stage' aanwezig
                                if(data.stage) {
                                    const row = document.getElementById('stage-' + data.stage.id);
                                    if (row) {
                                        row.innerHTML = `
                                            <td>${data.stage.date}</td>
                                            <td>${data.stage.name}</td>
                                            <td>${data.stage.start} → ${data.stage.finish}</td>
                                            <td class="text-end">
                                                <button class="btn btn-sm btn-outline-primary edit-stage-btn" data-url="/Stages/EditStage/${data.stage.id}">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <button type="button" class="btn btn-danger btn-sm delete-stage-btn" data-stage-id="${data.stage.id}">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </td>
                                        `;
                                    }
                                }

                                modal.hide(); // werkt altijd betrouwbaar
                                Swal.fire({ icon: 'success', title: 'Actie voltooid!' });
                            } else {
                                // Validation errors
                                modalContent.innerHTML = data.html;
                                initStageModalControls(modalContentId);
                            }
                        })
                        .catch(() => alert('Er is iets misgegaan bij het opslaan.'));
                }, { capture: true });
            }

            /*** Delete actie via SweetAlert2 ***/
            document.addEventListener('click', function(e) {
                const btn = e.target.closest('.delete-stage-btn');
                if (!btn) return;

                const stageId = btn.dataset.stageId;

                Swal.fire({
                    title: 'Weet je het zeker?',
                    text: "Deze etappe wordt permanent verwijderd!",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#3085d6',
                    confirmButtonText: 'Ja, verwijderen',
                    cancelButtonText: 'Annuleren'
                }).then((result) => {
                    if(result.isConfirmed) {
                        fetch(`/Stages/DeleteAjax/${stageId}`, {
                            method: 'POST',
                            headers: { 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value }
                        })
                        .then(res => res.json())
                        .then(data => {
                            if(data.success) {
                                const row = document.getElementById(`stage-${stageId}`);
                                if(row) row.remove();
                                Swal.fire('Verwijderd!', 'De etappe is verwijderd.', 'success');
                            } else {
                                Swal.fire('Fout', 'Kon de etappe niet verwijderen', 'error');
                            }
                        });
                    }
                });
            });

            /*** Edit stage buttons in modal ***/
            document.getElementById('manageStagesContent')?.addEventListener('click', function(e) {
                const editBtn = e.target.closest('.edit-stage-btn');
                if (!editBtn) return;

                e.preventDefault();
                const url = editBtn.dataset.url;

                fetch(url)
                    .then(res => res.text())
                    .then(html => {
                        const editModalContent = document.getElementById('editStageModalContent');
                        editModalContent.innerHTML = html;
                        initStageModalControls('editStageModalContent');

                        const editModal = bootstrap.Modal.getOrCreateInstance(document.getElementById('editStageModal'));
                        editModal.show();

                        // Bind AJAX form in deze modal
                        setupAjaxForm('editStageModalContent');
                    });
            });

            /*** Setup modals ***/
            setupModal('manageTeamsModal', 'manageTeamsContent');
            setupModal('manageStagesModal', 'manageStagesContent');

            /*** Bind forms in hoofdmodals ***/
            setupAjaxForm('manageStagesContent');
            setupAjaxForm('manageTeamsContent');

        });
    </script>
    <script>
        function initStageModalControls(modalContentId) {
            const container = document.getElementById(modalContentId);
            if (!container) return;

            const check = container.querySelector('#noScoreCheck');
            const wrapper = container.querySelector('#noScoreDescriptionWrapper');

            if (!check || !wrapper) return;

            // functie die show/hide doet
            const toggleDescription = () => {
                wrapper.style.display = check.checked ? 'block' : 'none';
            };

            // initialiseren
            toggleDescription();

            // oude listener verwijderen
            if (check._toggleListener) {
                check.removeEventListener('change', check._toggleListener);
            }

            // listener binden
            check._toggleListener = toggleDescription;
            check.addEventListener('change', toggleDescription);
        }    
    </script>
}
