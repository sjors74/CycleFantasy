@model IEnumerable<ConfigurationViewModel>
<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Configuraties</h3>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Maak nieuwe Configuratie
    </a>
</div>

<table class="table">
    <thead>
        <tr>
            <th>
                Naam
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.ConfigurationName)
            </td>
            <td>
                <div class="btn-group" role="group">
                    <a asp-action="Edit" asp-route-id="@item.Id"
                        class="btn btn-sm btn-outline-primary" title="Wijzig">
                        <i class="bi bi-pencil-square"></i>
                    </a>
                    <a asp-action="Details" asp-route-id="@item.Id"
                        class="btn btn-sm btn-outline-secondary" title="Details">
                        <i class="bi bi-eye"></i>
                    </a>
                    <a asp-action="Delete" asp-route-id="@item.Id"
                        class="btn btn-sm btn-outline-danger" title="Verwijder">
                        <i class="bi bi-trash"></i>
                    </a>
                </div>
            </td>
        </tr>
    }
    </tbody>
</table>
