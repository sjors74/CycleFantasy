@model ConfigurationViewModel
@{
    var half = (int)Math.Ceiling(Model.ConfigurationItems.Count / 2.0);
    var leftItems = Model.ConfigurationItems.OrderBy(c => c.Position).Take(half).ToList();
    var rightItems = Model.ConfigurationItems.OrderBy(c => c.Position).Skip(half).ToList();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Configuratie: @Model.ConfigurationName</h3>
    <div class="btn-group">
        <a asp-controller="ConfigurationItems"
           asp-action="Create"
           asp-route-configurationId="@Model.Id"
           class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Nieuw configuratie-item
        </a>

        <a asp-controller="ConfigurationItemSpecials"
           asp-action="Create"
           asp-route-configurationId="@Model.Id"
           class="btn btn-success ms-1">
            <i class="bi bi-plus-circle"></i> Nieuw special
        </a>
    </div>
</div>
<div class="row">
    @foreach (var column in new[] { leftItems, rightItems })
    {
        <div class="col-md-6">
            <table class="table table-striped table-hover align-middle shadow-sm">
              <thead class="table-light">
                <tr>
                    <th style="width:50px;">#</th>
                    <th>Score</th>
                    <th></th>
                </tr>
              </thead>
              <tbody>
               @foreach (var item in column)
               {
                <tr>
                    <td class="fw-bold text-muted">@item.Position</td>
                    <td>@item.Score</td>
                    <td class="text-end">
                        <div class="btn-group" role="group">
                             <a asp-controller="ConfigurationItems" asp-action="Edit" asp-route-id="@item.Id"
                                class="btn btn-sm btn-outline-primary" title="Wijzig">
                                <i class="bi bi-pencil-square"></i>
                            </a>
                            <a asp-controller="ConfigurationItems" asp-action="Delete" asp-route-id="@item.Id"
                                class="btn btn-sm btn-outline-danger" title="Verwijder">
                                <i class="bi bi-trash"></i>
                            </a>
                        </div>
                    </td>
                </tr>
             }
            </tbody>
         </table>
     </div>
    }
</div>

<div class="row">
        <div class="col-md-6">
            <table class="table table-striped table-hover align-middle shadow-sm">
                <thead class="table-light">
                    <tr>
                        <th>Question</th>
                        <th>Score</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.ConfigurationItemSpecials)
                    {
                        <tr>
                            <td class="fw-bold text-muted">@item.Question</td>
                            <td>@item.Score</td>
                            <td class="text-end">
                                <div class="btn-group" role="group">
                                    <a asp-controller="ConfigurationItemSpecials" asp-action="Edit" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-primary" title="Wijzig">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a asp-controller="ConfigurationItemSpecials" asp-action="Delete" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-danger" title="Verwijder">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
</div>
<div class="mt-3 d-flex justify-content-between gap-2">
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Terug naar de lijst
    </a>
    <a asp-action="Edit" class="btn btn-primary" asp-route-id="@Model?.Id">Wijzig</a>
</div>
