@model StageCreateViewModel

<h4>Nieuwe Etappe toevoegen</h4>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    
    <input type="hidden" asp-for="StageId" />

    <div class="row g-2 mb-2">
        <div class="col-md-3">
            <label asp-for="StageDate"></label>
            <input asp-for="StageDate" class="form-control" />
            <span asp-validation-for="StageDate" class="text-danger"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="StageName"></label>
            <input asp-for="StageName" class="form-control" />
            <span asp-validation-for="StageName" class="text-danger"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="StageOrder"></label>
            <input asp-for="StageOrder" class="form-control" />
            <span asp-validation-for="StageOrder" class="text-danger"></span>
        </div>

        <div class="col-md-2">
            <label asp-for="StartLocation"></label>
            <input asp-for="StartLocation" class="form-control" />
            <span asp-validation-for="StartLocation" class="text-danger"></span>
        </div>
        <div class="col-md-2">
            <label asp-for="FinishLocation"></label>
            <input asp-for="FinishLocation" class="form-control" />
            <span asp-validation-for="FinishLocation" class="text-danger"></span>
        </div>
        <div class="col-md-2 d-flex align-items-end">
            <button type="submit" class="btn btn-primary w-100">Opslaan</button>
        </div>
    </div>

    <div class="row g-2 mb-2">
        <div class="col-md-3">
            <label asp-for="EventId">Evenement</label>
            <select asp-for="EventId" class="form-control" asp-items="Model.Events"></select>
        </div>
        <div class="col-md-2 d-flex align-items-end">
            <div class="form-check">
                <input asp-for="NoScore" class="form-check-input" />
                <label asp-for="NoScore" class="form-check-label">Geen score</label>
            </div>
        </div>
        <div class="col-md-7">
            <label asp-for="NoScoreDescription">Omschrijving</label>
            <input asp-for="NoScoreDescription" class="form-control" />
        </div>
    </div>
</form>


<div>
    <a asp-action="Index">Terug naar lijst</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
