@using CycleManager.Domain.Enums
@model ConfigurationItemsSpecialViewModel

<h3>Wijzig configuratie-item-special</h3>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group">
                <label asp-for="Question" class="form-label"></label>
                <select asp-for="Question"
                        asp-items="Html.GetEnumSelectList<QuestionType>()"
                        class="form-select">
                </select>
                <span asp-validation-for="Question" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Score" class="form-label"></label>
                <input asp-for="Score" class="form-control" />
                <span asp-validation-for="Score" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ConfigurationId" class="control-label"></label>
                <select asp-for="ConfigurationId" class="form-control" asp-items="ViewBag.ConfigurationId"></select>
                <span asp-validation-for="ConfigurationId" class="text-danger"></span>
            </div>
            <div class="mt-3 d-flex justify-content-between">
                <a asp-controller="Configurations" asp-action="Details" asp-route-id="@Model.ConfigurationId" class="btn btn-outline-secondary">Terug naar de lijst</a>
                <button type="submit" class="btn btn-primary">Opslaan</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
