@model TeamEditViewModel

<h3>Bewerk team</h3>
<hr />
<form asp-action="Edit">
    <div class="row">
        <!-- Linkerkant: Algemene gegevens -->
        <div class="col-md-6">
            <h4>Algemene gegevens</h4>
            <input type="hidden" asp-for="TeamId" />
            <div class="form-group mb-2">
                <label class="form-label" asp-for="CurrentTeamName"></label>
                <input asp-for="CurrentTeamName" class="form-control" />
            </div>
            <div class="form-group mb-2">
                <label class="form-label" asp-for="CountryId"></label>
                <select asp-for="CountryId" class="form-control" asp-items="Model.Countries"></select>
            </div>
            <div class="form-group mb-2">
                <label class="form-label" asp-for="PcsName"></label>
                <input asp-for="PcsName" class="form-control" />
            </div>
        </div>

        <!-- Rechterkant: TeamYears per jaar -->
        <div class="col-md-6">
            <h4>Per jaar</h4>
            <ul class="nav nav-tabs" id="yearTabs" role="tablist">
                @for (int i = 0; i < Model.AvailableYears.Count; i++)
                {
                    var year = Model.AvailableYears[i];
                    <li class="nav-item" role="presentation">
                        <button class="nav-link @(i == 0 ? "active" : "")"
                                id="tab-@year"
                                data-bs-toggle="tab"
                                data-bs-target="#year-@year"
                                type="button"
                                role="tab">
                            @year
                        </button>
                    </li>
                }
            </ul>

            <div class="tab-content mt-3">
                @for (int i = 0; i < Model.AvailableYears.Count; i++)
                {
                    var year = Model.AvailableYears[i];
                    var teamYear = Model.TeamYears.FirstOrDefault(ty => ty.Year == year);
                    <div class="tab-pane fade @(i == 0 ? "show active" : "")" id="year-@year" role="tabpanel">
                        <div id="teamyear-container-@year">
                            @if (teamYear != null)
                            {
                                <input type="hidden" name="TeamYears[@i].TeamYearId" value="@teamYear.TeamYearId" />
                                <input type="hidden" name="TeamYears[@i].Year" value="@teamYear.Year" />
                                <div class="form-group">
                                    <label>Teamnaam</label>
                                    <input type="text" class="form-control" name="TeamYears[@i].TeamName" value="@teamYear.Name" />
                                </div>
                            }
                            else
                            {
                                <div class="no-teamyear">
                                    <em>Geen TeamYear aanwezig voor @year</em>
                                    <button type="button" class="btn btn-sm btn-outline-primary mt-2" onclick="createTeamYear(@year)">Maak TeamYear aan</button>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="mt-3 d-flex justify-content-between">
        <a asp-action="Index" class="btn btn-link">Terug naar de lijst</a>
        <button type="submit" class="btn btn-primary">Opslaan</button>
    </div>
</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        function createTeamYear(year) {
            var container = document.getElementById('teamyear-container-' + year);
            container.innerHTML = `
                <input type="hidden" name="TeamYears[${year}].Year" value="${year}" />
                <div class="form-group">
                    <label>Teamnaam</label>
                    <input type="text" class="form-control" name="TeamYears[${year}].TeamName" value="" />
                </div>
            `;
        }
    </script>
}
