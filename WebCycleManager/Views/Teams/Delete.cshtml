@model TeamDeleteViewModel
<h1 class="mb-4">Verwijder team</h1>

<div class="alert alert-warning">
    <h4 class="alert-heading">Weet je het zeker?</h4>
    <p>
        Je staat op het punt om het volgende team definitief te verwijderen:
    </p>
    <hr>
    <dl class="row mb-0">
        <dt class="col-sm-3">Teamnaam</dt>
        <dd class="col-sm-9">@Model.CurrentTeamName</dd>
    </dl>
</div>

<form asp-action="Delete" method="post" class="mt-3">
    <input type="hidden" asp-for="TeamId" />

    <div class="d-flex justify-content-between">
        <a asp-action="Index" class="btn btn-outline-secondary">Annuleren</a>
        <button type="submit" class="btn btn-danger">
            <i class="bi bi-trash"></i> Verwijder
        </button>
    </div>
</form>