@page
@model WebApp.Pages.EventModel

<style>
    .podium {
        display: flex;
        justify-content: center;
        align-items: flex-end;
        gap: 1rem;
        height: 180px;
    }

.podium .place {
        width: 100%;
        max-width:600px;
        margin: 0 auto;
        word-break: break-word;
        color: white;
        padding: 0.5rem;
        border-radius: 10px 10px 0 0;
        text-align: center;
        display: block;
        flex-direction: column;
        justify-content: flex-end;
    }

    .podium .place .naam {
        font-weight: bold;
        font-size: 1rem;
    }

   .podium .place .punten {
       font-size: 0.9rem;
    }

    .podium .place .plaatsnummer {
         margin-top: -6px;
         font-size: 2rem;
    }

    .place-1 {
        background: gold;
        height: 140px;
    }

    .place-2 {
        background: silver;
        height: 100px;
    }

    .place-3 {
        background: #cd7f32; /* brons */
        height: 80px;
    }

    .place.active {
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.4);
        outline: 3px solid #343a40;
    }

    @@media (max-width: 576px) {
        .podium .place {
            width: 100px;
            font-size: 0.85rem;
        }
    }
</style>

<div class="event-header">
    <div class="event-motto">
        <span class="quote">"</span><div  id="slogan"></div><span class="quote">"</span>
    </div>
    <h1 id="eventName"></h1>
    <div id="event-id" data-event-id="@Model.EventId"></div>
    <p class="event-dates">Van <span  id="startDate"></span> tot <span id="endDate"></span></p>
    <div class="progress-container">
        <div class="progress-bar" id="progress-bar"></div>
    </div>
    <div class="steps-wrapper">
        <div class="steps" id="steps-container"></div>
        <button id="top15-button" title="Bekijk top 15" aria-label="Top15">⭐</button>
    </div>
</div>

<div class="card shadow-sm mt-4">
    <div class="card-header bg-secondary text-white">
        <h5 class="mb-0">Deelnemers</h5>
    </div>
    <div class="card-body">
        <div id="podium-container" class="podium"></div>
        <ul class="list-group list-group-flush" id="deelnemer-list"></ul>
    </div>
</div>

@section Scripts {
    <script type="module" src="~/js/event.js" asp-append-version="true"></script>
    <script>
        document.getElementById("top15-button").addEventListener("click", () => {
            const eventId = document.getElementById("event-id").dataset.eventId;
            window.location.href = `/Top15?eventId=${eventId}`;
        });
    </script>
}