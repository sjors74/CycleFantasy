@page
@model WebApp.Pages.EventModel

<div class="event-header">
    <div id="event-id" data-event-id="@Model.EventId"></div>
    <h1>@Model.EventName</h1>
    <p class="event-dates">Van @Model.StartDate tot @Model.EndDate</p>
    <div class="progress-container">
        <div class="progress-bar" id="progress-bar"></div>
    </div>

    <div class="steps" id="steps-container"></div>
    <div class="event-motto">
        <span class="quote">"</span>
        @Model.Slogan
        <span class="quote">"</span>
    </div>
</div>

<div id="loader" class="spinner" style="display: none;"></div>

<h2>Deelnemers</h2>

<table id="deelnemerTable" border="1">
    <thead>
        <tr>
            <th>Poolnaam</th>
            <th>Ingezonden door</th>
            <th>Punten</th>
        </tr>
    </thead>
    <tbody></tbody>
</table>
@section Scripts {
    <script src="~/js/event.js" asp-append-version="true"></script>
}
    