@page
@using System.Text.Json
@model WebApp.Pages.SelectieModel
@{
    int pageSize = 3;
}
<h2>Renners-selectie (<span id="riderCountHeader">@Model.SelectedRiders.Count</span> van 15)</h2>
<form method="post" id="selectForm">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="EvenementId" />
    <input type="hidden" asp-for="DeelnemerId" />
    <input type="hidden" asp-for="PageIndex" />

    <input type="hidden"
           id="SelectedRidersJson"
           name="SelectedRidersJson"
           value='@JsonSerializer.Serialize(Model.SelectedRiders)' />

    <div class="top-buttons mb-4 d-flex justify-content-center gap-2">
        <button type="submit" asp-page-handler="Bevestigen" class="btn btn-primary">Bevestig selectie</button>
        <a href="/Account/Profiel" class="btn btn-outline-danger">Annuleren</a>
        <button type="button" id="suggestieBtn" class="btn btn-outline-dark" onclick="voegWillekeurigeRennersToe(@Model.EvenementId)">Doe een sugestie</button>
    </div>

    <!-- Navigatie boven de teams -->
    <div class="d-flex justify-content-between mb-3">

        <button type="submit"
                name="action"
                value="previous"
                class="btn btn-outline-primary">
            ← Vorige
        </button>

        <button type="submit"
                name="action"
                value="next"
                class="btn btn-outline-primary">
            Volgende →
        </button>

    </div>

    <div class="row g-4">
        @foreach (var team in Model.VisibleTeams)
        {
            var initialIds = team.Renners
                .Select(r => r.CompetitorInTeamId)
                .ToList();
            <div class="col-md-4 d-flex">
                <div class="card w-100 d-flex flex-column p-3 h-100 shadow-sm"
                     data-team-id="@team.Id">

                    <h5 class="card-title">@team.Naam</h5>

                    @if (team.Renners.Any(r => r.RemovedFromStartlist))
                    {
                        <div class="alert alert-warning py-2 mb-3">
                            <strong>Niet meer op de startlijst:</strong>

                            @foreach (var renner in team.Renners.Where(r => r.RemovedFromStartlist))
                            {
                                <div>
                                    @renner.FirstName @renner.LastName
                                </div>
                            }
                        </div>
                    }

                    <div class="flex-grow-1">

                        <!-- ONLY SELECTED -->
                        @if (team.Renners.Any())
                        {
                            <strong class="d-block mb-2 selected-header">
                                Geselecteerd
                            </strong>

                            @foreach (var renner in team.Renners)
                            {
                                var isMax = Model.SelectedRiders.Count >= 15;
                                var isChecked = Model.SelectedRiders.Contains(renner.CompetitorInTeamId);

                                <div class="form-check mb-1">

                                    <input type="checkbox"
                                           class="form-check-input renner-checkbox"
                                           value="@renner.CompetitorInTeamId"
                                           @(isChecked ? "checked" : "")
                                           @((isMax && !isChecked) ? "disabled" : "") />


                                    <label class="form-check-label">

                                        @renner.FirstName @renner.LastName

                                        @if (renner.RemovedFromStartlist)
                                        {
                                            <span class="badge bg-danger ms-2">
                                                Niet op startlijst
                                            </span>
                                        }

                                    </label>

                                </div>
                            }
                        }

                        <!-- EXTRA NOT YET LOADED -->
                        <div class="team-extra"></div>

                    </div>

                    <div class="mt-auto">
                        <button type="button"
                                class="btn btn-outline-primary w-100 show-more-btn"
                                data-team-id="@team.Id"
                                data-loaded-ids="@string.Join(",", initialIds)"
                                data-expanded="false">
                            Meer...
                        </button>
                    </div>

                </div>
            </div>
        }
    </div>
    
</form>
@section Scripts {
    <script type="module">
        import { voegWillekeurigeRennersToe } from '/js/selectie.js';
        window.voegWillekeurigeRennersToe = voegWillekeurigeRennersToe;
    </script>
    <script>
        document.addEventListener("click", async (e) => {

            const btn = e.target.closest(".show-more-btn");
            if (!btn) return;

            const card = btn.closest(".card");
            const container = card.querySelector(".team-extra");

            const isExpanded = btn.dataset.expanded === "true";
            const teamId = btn.dataset.teamId;

            const selectedIds = Array.from(
                document.querySelectorAll(".renner-checkbox:checked")
            ).map(x => parseInt(x.value));

            // COLLAPSE
            if (isExpanded) {
                container.innerHTML = "";
                btn.textContent = "Meer...";
                btn.dataset.expanded = "false";
                return;
            }

            // EXPAND
            btn.textContent = "Laden...";
            btn.dataset.expanded = "true";

            const response = await fetch(
                `${API_BASE_URL}/api/event/team/${teamId}/teams-with-more-renners`
            );

            const riders = await response.json();

            const zichtbaarIds = new Set(
                Array.from(
                    card.querySelectorAll(".renner-checkbox")
                ).map(cb => parseInt(cb.value))
            );

        const notSelected = riders
            .filter(r => !zichtbaarIds.has(r.competitorInTeamId))
            .sort((a, b) => a.lastName.localeCompare(b.lastName));

        container.innerHTML = `
            <strong class="d-block mb-2 not-selected-header">
                Niet geselecteerd
            </strong>

            ${notSelected.map(r => `
                <div class="form-check mb-1">

                    <input type="checkbox"
                           class="form-check-input renner-checkbox"
                           value="${r.competitorInTeamId}" />

                    <span class="rider-name">
                        ${r.firstName} ${r.lastName}
                    </span>

                </div>
            `).join("")}
        `;

        btn.textContent = "Minder...";
        });
    </script>

}