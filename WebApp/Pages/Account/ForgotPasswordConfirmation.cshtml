@page


<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">E-mail verzonden</h4>
                </div>
                <div class="card-body">
                    <p class="text-muted">
                        Als het e-mailadres bij ons bekend is, heb je zojuist een e-mail ontvangen met een link om je wachtwoord opnieuw in te stellen.
                    </p>
                    <p class="text-muted">
                        Controleer je inbox (en eventueel je spamfolder).
                    </p>
                    <p class="mt-3">
                        <a asp-page="/Account/Login">Terug naar inloggen</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>