@page
@model WebApp.Pages.Account.ProfielModel
@{
}
<div class="container mt-4">
    <div class="row">
    <!-- sidebar -->
        <div class="col=md-3">
            <div class="list-group w-100">
                <a href="#" class="list-group-item list-group-item-action active">Dashboard</a>
                <a href="#" class="list-group-item list-group-item-action">Instellingen</a>
                <a href="#" class="list-group-item list-group-item-action">Berichten</a>
                <a href="#" class="list-group-item list-group-item-action">Notificaties</a>
            </div>

            <!-- Main Content -->
            <div class="col-md-9">
                <div class="row">
                    <!-- Knoppen -->
                    <div class="col-md-4 mb-3">
                        <div class="card">
                            <div class="card-body">
                                <h5 class="card-title">Nieuwe Taak</h5>
                                <p class="card-text">Maak een nieuwe taak aan.</p>
                                <a href="#" class="btn btn-primary">Start</a>
                            </div>
                        </div>
                    </div>

                    <!-- Grafiek -->
                    <div class="col-md-8 mb-3">
                        <div class="card">
                            <div class="card-body">
                                <h5 class="card-title">Activiteitsoverzicht</h5>
                                <canvas id="activityChart"></canvas>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Lijst -->
                <div class="card">
                    <div class="card-header">
                        Recent Activiteit
                    </div>
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item">Taak 1 voltooid</li>
                        <li class="list-group-item">Nieuwe bericht ontvangen</li>
                        <li class="list-group-item">Instellingen bijgewerkt</li>
                    </ul>
                </div>
            </div>
        </div>
 </div>

</div>




