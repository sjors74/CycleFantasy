@using Domain.Dto
@using WebApp.Pages.ViewModels
@model EventListViewModel
<div class="card shadow-sm mt-4">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0">@Model.Titel</h5>
    </div>
    <div class="card-body">
        @if (!Model.Evenementen.Any())  //TODO: add boolean 'inschrijving geopend => if true show button 'maak pool aan'
        {
            <p class="text-muted">Er zijn momenteel geen @Model.InlineText evenementen.</p>
        }
        else
        {
            <ul class="list-group list-group-flush">
                @foreach (var evt in Model.Evenementen)
                {
                    var collapseId = $"collapse-{evt.EventId}";
                    <li class="list-group-item">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <strong>@evt.EventName</strong><br />
                                @evt.StartDate.ToString("dd MMM yyyy") - @evt.EndDate.ToString("dd MMM yyyy")
                            </div>
                            <button class="btn btn-sm btn-primary" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId" aria-expanded="false" aria-controls="@collapseId">
                                Details
                            </button>

                        </div>
                        <div class="collapse mt-2" id="@collapseId">
                            <div class="card card-body">

                                <p><strong>Je pools</strong></p>
                                @if (evt.Deelnemers != null && evt.Deelnemers.Any())
                                {
                                    <ul class="list-group mt-3">

                                        @foreach(var deelnemer in evt.Deelnemers)
                                        {
                                            var deelnemerCollapseId = $"collapse-deelnemer-{deelnemer.Id}";
                                            <li class="list-group-item ">
                                                @* <div class="row"> *@
                                                <div class="d-flex justify-content-between align-items-center">
                                                    <div>
                                                        <div class="fw-bold">@deelnemer.PoolNaam</div>
                                                        <div class="text-muted">@deelnemer.Renners.Count renners geselecteerd</div>
                                                    </div>
                                                    <div class="text-end">
                                                        @if (Model.ShowLinkToevoegen)
                                                        {
                                                            <a class="btn btn-sm btn-secondary me-2" href="/Selectie?EvenementId=@evt.EventId&DeelnemerId=@deelnemer.Id">Voeg renners toe</a>
                                                        }
                                                    </div>
                                                    <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="collapse" data-bs-target="#@deelnemerCollapseId" aria-expanded="false" aria-controls="@deelnemerCollapseId">
                                                        Renners
                                                    </button>
                                                </div>
                                                <div class="collapse mt-2" id="@deelnemerCollapseId">

                                                @if (deelnemer.Renners != null && deelnemer.Renners.Any())
                                                {
                                                  <ul class="list-group mt-2">
                                                  @* <p><strong>Je geselecteerde renners</strong></p> *@

                                                  @foreach (var renner in deelnemer.Renners)
                                                  {
                                                    <li class="list-group-item">
                                                        <div class="row">
                                                            <div class="col-md-1">
                                                                <img src="https://flagcdn.com/24x18/@(renner.CountryShort?.ToLower() ?? "unknown").png" alt="Vlag" />
                                                            </div>
                                                            <div class="col-md-3 fw-bold">@renner.CompetitorName</div>
                                                            <div class="col-md-4 text-muted">@renner.TeamName</div>
                                                            <div class="col-md-2 text-end">@renner.Punten</div>
                                                        </div>
                                                    </li>
                                                   }
                                                </ul>
                                            }
                                            else
                                            {
                                                        <p class="text-muted mt-2">Geen renners geselecteerd.</p>
                                            }
                                        </div>
                                    </li>
                                 }
                                    </ul>
                                }
                                <!-- Pool toevoegen: altijd zichtbaar -->
                                <div class="mt-4">
                                    <button class="btn btn-outline-primary mb-3" type="button" data-bs-toggle="collapse" data-bs-target="#poolFormCollapse" aria-expanded="false" aria-controls="poolFormCollapse">
                                        + Pool aanmaken
                                    </button>

                                    <div class="collapse" id="poolFormCollapse">
                                        <form method="post" asp-page-handler="CreatePool">
                                            <div class="mb-3">
                                                <label for="poolNaam" class="form-label">Pool Naam</label>
                                                <input type="text" class="form-control" id="poolNaam" name="poolNaam" required />
                                                <input type="hidden" asp-for="CurrentEventId" id="CurrentEventId" name="CurrentEventId" value="@evt.EventId" />
                                            </div>
                                            <button type="submit" class="btn btn-primary">Voeg toe</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </li>
                }
            </ul>
        }
    </div>
</div>